# Copier ce fichier en `.env.local` (gitignoré) et renseigner les valeurs
# réelles. Les scripts de publication chargent `.env.local` automatiquement.
# Ne jamais mettre de valeur réelle ici : ce fichier est versionné (repo public).

# ─── Publication des releases (scripts/publish-*.sh) ───

# OTA, live-update web (scripts/publish-bundle.sh, npm run release:ota)
PHOTOGRID_OTA_HOST=your-ssh-host          # hôte ou alias SSH de destination
PHOTOGRID_OTA_DIR=/path/to/ota/photogrid  # dossier distant (bundles + updates.json)

# APK signé (scripts/publish-apk.sh, npm run release:apk)
PHOTOGRID_REMOTE_HOST=your-ssh-host        # hôte ou alias SSH de destination
PHOTOGRID_REMOTE_DIR=/path/to/apk-releases # dossier distant des APK

# ─── Déploiement du service OTA côté serveur (docker-compose) ───

# Sous-domaine public sous lequel le service répond (routé par Traefik).
PUBLIC_DOMAIN=photogrid.example.com

# Chemin hôte du dossier servant les artefacts OTA (bundles + manifest),
# monté en lecture seule sur /ota. Dossier dédié, hors de toute donnée privée.
OTA_DATA_DIR=/srv/photogrid-ota
